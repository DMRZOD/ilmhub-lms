# =========================
# Server
# =========================
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# =========================
# Database — Supabase PostgreSQL
# =========================
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
# DATABASE_URL: Transaction pooler (port 6543), used at runtime by @prisma/client
# DIRECT_URL:   Direct/session connection (port 5432), used by `prisma migrate`
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# =========================
# Auth — JWT
# =========================
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_to_a_random_32_byte_string_min_16_chars
JWT_REFRESH_SECRET=change_me_to_another_random_32_byte_string

# Public frontend URL — used to build links in verification/reset emails.
FRONTEND_URL=http://localhost:3000

# =========================
# Google OAuth (Step 11)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_CALLBACK_URL below.
# If GOOGLE_CLIENT_ID is empty, /auth/google routes are disabled.
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# =========================
# Email — Resend (Step 10)
# If RESEND_API_KEY is empty, EmailService falls back to logging the message at
# info level via Pino (registration still works — useful for local dev).
# =========================
RESEND_API_KEY=
EMAIL_FROM=noreply@ilmhub.uz

# =========================
# Redis for BullMQ (placeholder — needed for queue-based steps)
# =========================
REDIS_URL=redis://localhost:6379

# =========================
# Mux video (Step 19 — Lesson Player)
# MUX_TOKEN_ID / MUX_TOKEN_SECRET — API credentials (Mux Dashboard → Settings → Access Tokens)
# MUX_SIGNING_KEY_ID / MUX_PRIVATE_KEY — used to sign playback JWTs for SIGNED-policy assets
#   (Dashboard → Settings → Signing Keys; MUX_PRIVATE_KEY is the base64-encoded RSA private key)
# All four can stay empty in local dev — seeded Mux test playback IDs use PUBLIC policy and
# don't require signing. Endpoints will 503 for SIGNED lessons if signing creds are missing.
# =========================
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_PRIVATE_KEY=
# MUX_WEBHOOK_SECRET — signing secret for POST /webhooks/mux (Dashboard → Settings →
#   Webhooks). When set, incoming webhooks are signature-verified; empty in dev accepts
#   unsigned JSON so you can simulate `video.asset.ready` locally.
MUX_WEBHOOK_SECRET=

# =========================
# Payments — Payme (placeholder — wired up in Step 24)
# =========================
PAYME_MERCHANT_ID=

# =========================
# Tests — separate database for e2e runs
# If unset, e2e specs are skipped. NEVER point this at DATABASE_URL.
# =========================
TEST_DATABASE_URL=

# Supabase Storage (course images) — create a public bucket, then fill these
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=course-assets
