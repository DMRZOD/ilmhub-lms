auto-install-peers=true
strict-peer-dependencies=false
# Skip pnpm's pre-run deps check. sharp pulls in @scarf/scarf (telemetry) which
# stays in pnpm's "ignored builds" list and would otherwise fail `pnpm build` /
# `pnpm start:dev` with ERR_PNPM_IGNORED_BUILDS. sharp itself is built (see
# allowBuilds: sharp in pnpm-workspace.yaml).
verify-deps-before-run=false
