{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      { "tsconfig": "<rootDir>/test/tsconfig.json", "isolatedModules": true }
    ],
    "^.+\\.js$": ["ts-jest", { "isolatedModules": true }]
  },
  "transformIgnorePatterns": [
    "/node_modules/.pnpm/(?!(keyv|@keyv\\+redis|cacheable|cache-manager|@redis\\+client|@keyv\\+serialize)@)"
  ],
  "moduleNameMapper": {
    "^puppeteer$": "<rootDir>/test/mocks/puppeteer.ts"
  },
  "testTimeout": 30000,
  "maxWorkers": 1
}
