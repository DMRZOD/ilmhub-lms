# =========================
# Backend API base URL — consumed by the axios client and server-side fetch.
# Local dev points at the NestJS backend on :3001.
# Production: NEXT_PUBLIC_API_URL=https://api.ilmhub.uz
# =========================
NEXT_PUBLIC_API_URL=http://localhost:3001

# =========================
# Canonical site URL — used for canonical tags, Open Graph, sitemap and robots.
# Defaults to https://ilmhub.uz when unset. On Vercel previews you can leave it
# unset (defaults to prod) or set it to the preview URL.
# =========================
NEXT_PUBLIC_SITE_URL=https://ilmhub.uz

# =========================
# Sentry (Step 44) — error monitoring.
# NEXT_PUBLIC_SENTRY_DSN is the public DSN of your Sentry "Next.js" project.
# SENTRY_AUTH_TOKEN / SENTRY_ORG / SENTRY_PROJECT are build-time only (set them
# in Vercel, NOT committed) and enable source-map upload during `next build`.
# Leave all empty in local dev → Sentry is a no-op.
# =========================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
